# URL do backend FastAPI (dev local)
LANGGRAPH_API_BASE=http://127.0.0.1:8000

# URL do backend em producao (descomente e ajuste)
#LANGGRAPH_API_BASE=https://api.seudominio.com

# Passkeys aceitas no login (uma ou varias separadas por virgula)
CONSOLE_PASSKEY=troque-esta-senha
#CONSOLE_PASSKEYS=senha-time-1,senha-time-2

# Segredo para assinar token de sessao (minimo 32 caracteres)
CONSOLE_AUTH_SECRET=troque-por-um-segredo-longo-com-32-caracteres

# TTL da sessao (segundos). Ex: 8 horas
CONSOLE_SESSION_TTL_SECONDS=28800

# Chave de servico enviada do Next server para o FastAPI
BACKEND_API_KEY=troque-por-chave-forte
BACKEND_API_KEY_HEADER=X-API-Key
