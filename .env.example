# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Modelo LLM (chat dos agentes) ---
# Opções: gpt-4o-mini (barato), gpt-4o (melhor), gpt-3.5-turbo (econômico)
LLM_MODEL=gpt-4o-mini
ALLOWED_CHAT_MODELS=gpt-4o-mini,gpt-4o
# CONSOLIDATION_TIMEOUT_SEC=10

# --- Modelo de embeddings ---
# Não mude sem re-ingerir todos os documentos!
EMBEDDING_MODEL=text-embedding-3-small

# --- Supabase (vector store) ---
# Pegue em: Supabase Dashboard → Settings → Database → Connection string
# Use Session Pooler se Direct connection não funcionar (IPv6)
SUPABASE_DB_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
TEST_EVALUATIONS_STORAGE=memory
THREADS_STORAGE=memory

# --- Streaming visual do shell/Next (fallback quando a resposta vem em bloco) ---
# Não altera o streaming real do backend/modelo; apenas a sensação visual de "digitando"
# na camada do frontend quando o orquestrador devolver chunks grandes.
# STREAM_FALLBACK_SPLIT_THRESHOLD=48
# STREAM_FALLBACK_MAX_SEGMENT=14
# STREAM_FALLBACK_DELAY_MS=18

# --- Postgres Hetzner (memory + logs) ---
HETZNER_DB_URL=postgresql://postgres:SUA_SENHA@5.161.236.220:5432/postgres

# --- Pool de conexões (produção) ---
# Transaction Pooler (porta 6543): pode usar 8-10 sem risco de EMAXCONNSESSION.
# Session Pooler (porta 5432): manter em 3-4 (limite de 15 conexões compartilhadas).
SUPABASE_DB_POOL_MIN_SIZE=1
SUPABASE_DB_POOL_MAX_SIZE=8
SUPABASE_DB_POOL_TIMEOUT_SEC=12
SUPABASE_DB_POOL_RECONNECT_TIMEOUT_SEC=30
SUPABASE_DB_CONNECT_TIMEOUT_SEC=8
HETZNER_DB_POOL_MIN_SIZE=1
HETZNER_DB_POOL_MAX_SIZE=4
HETZNER_DB_POOL_TIMEOUT_SEC=12
HETZNER_DB_POOL_RECONNECT_TIMEOUT_SEC=30
HETZNER_DB_CONNECT_TIMEOUT_SEC=8
# psycopg3 prepared statements:
# Em ambientes com pooler (Supabase/PgBouncer), manter "none" evita erro
# intermitente: prepared statement "... does not exist".
# Use um inteiro >= 0 apenas se você tiver garantia de compatibilidade.
SUPABASE_DB_PREPARE_THRESHOLD=none
HETZNER_DB_PREPARE_THRESHOLD=none

# --- RAG: busca ---
# Fase 1: vector | Fase 2: hybrid_rrf
DEFAULT_SEARCH_TYPE=vector
DEFAULT_K=5
# MATCH_THRESHOLD=0.3

# --- Reranking (Fase 3, opcional) ---
RERANKER=none
# COHERE_API_KEY=...
# RERANK_CANDIDATES=24

# --- HyDE (Fase 4, opcional) ---
USE_HYDE=false
# HYDE_LLM_MODEL=gpt-4o-mini

# --- Query Rewriting (Fase 2, opcional) ---
USE_QUERY_REWRITE=false
# QUERY_REWRITE_MODEL=gpt-4o-mini
# QUERY_REWRITE_VARIANTS=2
# RAG_MIN_CHUNK_CHARS=60
# RAG_MIN_ALNUM_RATIO=0.25

# --- Retrieval second-pass fallback (opcional) ---
# Ativa uma 2a passada quando a 1a recuperar pouco contexto.
# Recomendação: se USE_QUERY_REWRITE=true, prefira usar o rewrite apenas aqui,
# para evitar custo fixo na primeira passada de toda busca.
# RAG_SECOND_PASS_ENABLED=true
# RAG_SECOND_PASS_MIN_RESULTS=3
# RAG_SECOND_PASS_MIN_KEYWORD_HITS=1
# RAG_SECOND_PASS_EXPAND_FACTOR=2.5
# RAG_SECOND_PASS_MAX_K=20
# RAG_SECOND_PASS_FORCE_HYBRID=true
# RAG_SECOND_PASS_DISABLE_THRESHOLD=true
# RAG_SECOND_PASS_USE_QUERY_REWRITE=true

# --- Early-skip conservador para busca fraca (opcional) ---
# Use rollout controlado. Recomendado apenas para a base geral.
# RAG_EARLY_SKIP_WEAK_SEARCH_ENABLED=false
# RAG_EARLY_SKIP_WEAK_AGENT_IDS=0
# RAG_EARLY_SKIP_WEAK_MIN_QUERY_KEYWORDS=3
# RAG_EARLY_SKIP_WEAK_MIN_TOP_KEYWORD_HITS=2
# RAG_EARLY_SKIP_WEAK_HYBRID_MAX_SCORE=0.059

# --- Orquestrador: fallback final em base geral unificada (opcional) ---
# Mantenha DESLIGADO por padrão. Ative via rollout controlado.
# ENABLE_GENERAL_INDEX_FALLBACK=false
# GENERAL_INDEX_FALLBACK_SEARCH_TYPE=hybrid_rrf
# GENERAL_INDEX_FALLBACK_PER_TABLE_K=3
# GENERAL_INDEX_FALLBACK_FINAL_K=6
# GENERAL_INDEX_FALLBACK_MIN_RESULTS=2
# GENERAL_INDEX_FALLBACK_MAX_TABLES=7
# GENERAL_INDEX_FALLBACK_ONLY_ON_WEAK=true
# GENERAL_INDEX_FALLBACK_REQUIRE_DAIRY_SIGNAL=true

# --- Orquestrador: fallback final na internet (última camada, opcional) ---
# Mantenha DESLIGADO por padrão. Use whitelist de domínios confiáveis.
# ENABLE_WEB_FALLBACK=false
# WEB_FALLBACK_PROVIDER=duckduckgo
# WEB_FALLBACK_TIMEOUT_SEC=8
# WEB_FALLBACK_MAX_RESULTS=6
# WEB_FALLBACK_MAX_SOURCES=3
# WEB_FALLBACK_ONLY_ON_WEAK=true
# WEB_FALLBACK_REQUIRE_DAIRY_SIGNAL=true
# WEB_FALLBACK_REQUIRE_GENERAL_FALLBACK_FIRST=true
# WEB_FALLBACK_FETCH_FULLTEXT=false
# WEB_FALLBACK_ALLOWED_DOMAINS=gov.br,anvisa.gov.br,agricultura.gov.br,in.gov.br,planalto.gov.br,fao.org,who.int,codexalimentarius.fao.org,mercosur.int,iso.org,novonesis.com,chr-hansen.com,dsm.com,dsm-firmenich.com,ncbi.nlm.nih.gov,pmc.ncbi.nlm.nih.gov,sciencedirect.com
# WEB_FALLBACK_MAX_PAGE_CHARS=2800
# WEB_FALLBACK_MAX_SNIPPET_CHARS=420
# WEB_FALLBACK_ALLOWED_DOMAINS=gov.br,anvisa.gov.br,agricultura.gov.br,in.gov.br,planalto.gov.br,fao.org,who.int,codexalimentarius.fao.org,mercosur.int,iso.org

# --- Chat memory ---
MEMORY_WINDOW=10
ORCHESTRATOR_CONTEXT_MEMORY_ENABLED=true
ORCHESTRATOR_CONTEXT_MAX_MESSAGES=6
ORCHESTRATOR_CONTEXT_MAX_CHARS=1200
ORCHESTRATOR_CONTEXT_TRIGGER_MAX_CHARS=220

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Seguranca de acesso aos webhooks ---
# Dominios permitidos no CORS (separados por virgula)
CORS_ALLOW_ORIGINS=http://localhost:3000

# Exigir chave de API no backend para chamadas /webhook/*
ENFORCE_WEBHOOK_API_KEY=true
WEBHOOK_API_KEY_HEADER=X-API-Key
WEBHOOK_API_KEYS=troque-por-chave-forte

# --- Ingestão ---
DEFAULT_CHUNK_STRATEGY=markdown
# INGEST_MIN_TEXT_CHARS=400
# INGEST_MIN_WORDS=80
# INGEST_MAX_GARBLED_RATIO=0.08
# INGEST_MIN_QUALITY_SCORE=60
# Overrides para glossario (documentos curtos/tabulares)
# INGEST_MIN_TEXT_CHARS_GLOSSARIO=250
# INGEST_MIN_WORDS_GLOSSARIO=30

# --- Langfuse (observabilidade + feedback loop) ---
# Gere em: https://langfuse.com ou self-hosted
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=http://dairy-langfuse:3000

# Configuração interna do Langfuse (self-hosted)
# LANGFUSE_DATABASE_URL=postgresql://postgres:SUA_SENHA@5.161.236.220:5432/langfuse
# LANGFUSE_NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
# LANGFUSE_SALT=gere-com-openssl-rand-base64-32
# LANGFUSE_NEXTAUTH_URL=https://langfuse.seudominio.com
