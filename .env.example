# ============================================================
# .env.example — Template de variáveis de ambiente
#
# Copie para .env e preencha com seus valores:
#   cp .env.example .env
#
# NUNCA commite o .env no Git (já está no .gitignore)
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Modelo LLM (chat dos agentes) ---
# Opções: gpt-4o-mini (barato), gpt-4o (melhor), gpt-3.5-turbo (econômico)
LLM_MODEL=gpt-4o-mini

# --- Modelo de embeddings ---
# Não mude sem re-ingerir todos os documentos!
EMBEDDING_MODEL=text-embedding-3-small

# --- Supabase (vector store) ---
# Pegue em: Supabase Dashboard → Settings → Database → Connection string
# Use Session Pooler se Direct connection não funcionar (IPv6)
SUPABASE_DB_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# --- Postgres Hetzner (memory + logs) ---
HETZNER_DB_URL=postgresql://postgres:SUA_SENHA@5.161.236.220:5432/postgres

# --- RAG: busca ---
# Fase 1: vector | Fase 2: hybrid_rrf
DEFAULT_SEARCH_TYPE=vector
DEFAULT_K=5
# MATCH_THRESHOLD=0.3

# --- Reranking (Fase 3, opcional) ---
RERANKER=none
# COHERE_API_KEY=...
# RERANK_CANDIDATES=24

# --- HyDE (Fase 4, opcional) ---
USE_HYDE=false
# HYDE_LLM_MODEL=gpt-4o-mini

# --- Chat memory ---
MEMORY_WINDOW=10

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- Seguranca de acesso aos webhooks ---
# Dominios permitidos no CORS (separados por virgula)
CORS_ALLOW_ORIGINS=http://localhost:3000

# Exigir chave de API no backend para chamadas /webhook/*
ENFORCE_WEBHOOK_API_KEY=true
WEBHOOK_API_KEY_HEADER=X-API-Key
WEBHOOK_API_KEYS=troque-por-chave-forte

# --- Ingestão ---
DEFAULT_CHUNK_STRATEGY=markdown
